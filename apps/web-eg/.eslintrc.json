{
  "extends": ["../../.eslintrc.json"],
  "ignorePatterns": [
    "!**/*",
    ".next/**",
    "out/**",
    "dist/**",
    "node_modules/**",
    "public/sw.js",
    "public/workbox-*.js",
    "public/swe-worker-*.js",
    "public/fallback-*.js"
  ],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "extends": ["next/core-web-vitals"],
      "rules": {
        "@next/next/no-html-link-for-pages": "off"
      }
    }
  ]
}
