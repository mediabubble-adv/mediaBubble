{
  "name": "web-ae",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web-ae",
  "projectType": "application",
  "tags": ["type:app", "scope:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/web-ae",
        "tty": false,
        "command": "next build --webpack"
      },
      "outputs": [
        "{workspaceRoot}/apps/web-ae/.next/!(cache)/**/*",
        "{workspaceRoot}/apps/web-ae/.next/!(cache)"
      ]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/web-ae/tsconfig.json --noEmit"
      }
    },
    "dev": {
      "options": {
        "port": 3001
      }
    }
  }
}
