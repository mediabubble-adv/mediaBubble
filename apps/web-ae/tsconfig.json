{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@mediabubble/design-system": ["../../packages/design-system/src/index.ts"],
      "@mediabubble/design-system/tailwind-preset": [
        "../../packages/design-system/src/tailwind-preset.ts"
      ],
      "@mediabubble/shared": ["../../packages/shared/src/index.ts"],
      "@mediabubble/shared/client": ["../../packages/shared/src/client.ts"],
      "@mediabubble/shared/server": ["../../packages/shared/src/server.ts"],
      "@mediabubble/shared/ui/marketing-kicker": [
        "../../packages/shared/src/ui/marketing-kicker.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/design-system/src/tailwindcss-rtl.d.ts"
  ],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx", "**/*.stories.tsx"]
}
