# launcher.mediabubble.co — environment template
# Copy to .env.local (git-ignored) and fill in real values.

# PostgreSQL 14+ connection string (Prisma). Any host works — e.g. Neon,
# Supabase, or local Postgres. Use connection pooling in production.
DATABASE_URL="postgresql://user:password@localhost:5432/launcher?schema=public"

# Redis (Phase 1 Week 2+: rate limiting, pub/sub, presence). Not required yet.
REDIS_URL="redis://localhost:6379"

# Auth (Phase 1 Week 2). Generate a strong random secret for JWT signing.
JWT_SECRET="change-me-in-production"

# Google Calendar OAuth (Phase 1 Week 3, Time Management sync).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
