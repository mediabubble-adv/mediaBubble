# launcher.mediabubble.co — environment template
# Copy to .env.local (git-ignored) and fill in real values.

# Transaction-mode pooler (runtime queries, IPv4)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session-mode pooler (Prisma migrations). Required on Vercel — Prisma Compute
# only injects DATABASE_URL; set DIRECT_URL to the same value as DATABASE_URL there,
# or use Supabase session pooler (port 5432) when DATABASE_URL is the transaction pooler.
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Redis — pub/sub for Chat realtime (local: redis://localhost:6379; prod: Upstash TCP URL)
REDIS_URL="redis://localhost:6379"

# Chat WebSocket bridge (run `pnpm run ws:launcher` alongside dev). Port 3004 default.
COMMS_WS_PORT="3004"
NEXT_PUBLIC_COMMS_WS_URL="ws://localhost:3004"

# Auth (required). Generate: openssl rand -base64 48
JWT_SECRET="change-me-in-production"

# Resend (required in production for verify/reset email)
RESEND_API_KEY=""

# Public site URL for auth email links (required in production)
NEXT_PUBLIC_SITE_URL="http://localhost:3003"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI Tools (Prompt Studio). Optional — without this, runs use offline mock output.
GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"
