generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model activity_logs {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  action      String   @db.VarChar(100)
  entity_type String   @db.VarChar(100)
  entity_id   String   @db.Uuid
  details     Json?
  created_at  DateTime @default(now()) @db.Timestamp(6)
  users       users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at], map: "idx_activity_logs_created_at")
  @@index([entity_type, entity_id], map: "idx_activity_logs_entity")
  @@index([user_id], map: "idx_activity_logs_user_id")
}

model ai_configurations {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String   @db.VarChar(255)
  provider      String?  @db.VarChar(50)
  model         String?  @db.VarChar(100)
  temperature   Decimal? @db.Decimal(3, 2)
  max_tokens    Int?
  system_prompt String?
  created_by    String   @db.Uuid
  is_public     Boolean? @default(false)
  created_at    DateTime @default(now()) @db.Timestamp(6)
  users         users    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_by], map: "idx_ai_configurations_created_by")
}

model ai_outputs {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  request_id  String      @db.Uuid
  title       String?     @db.VarChar(255)
  content     String?
  tags        String[]
  starred     Boolean?    @default(false)
  user_id     String      @db.Uuid
  created_at  DateTime    @default(now()) @db.Timestamp(6)
  ai_requests ai_requests @relation(fields: [request_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([request_id], map: "idx_ai_outputs_request_id")
  @@index([user_id], map: "idx_ai_outputs_user_id")
}

model ai_requests {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String       @db.Uuid
  ai_provider   String?      @db.VarChar(50)
  request_type  String?      @db.VarChar(50)
  input_text    String?
  output_text   String?
  tokens_used   Int?
  cost          Decimal?     @db.Decimal(10, 6)
  status        String?      @default("Processing") @db.VarChar(50)
  error_message String?
  created_at    DateTime     @default(now()) @db.Timestamp(6)
  ai_outputs    ai_outputs[]
  users         users        @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at], map: "idx_ai_requests_created_at")
  @@index([user_id], map: "idx_ai_requests_user_id")
}

model api_keys {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  key_hash     String    @unique @db.VarChar(255)
  name         String?   @db.VarChar(255)
  permissions  String[]  @default([])
  last_used_at DateTime? @db.Timestamp(6)
  expires_at   DateTime? @db.Timestamp(6)
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  revoked_at   DateTime? @db.Timestamp(6)
  users        users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id], map: "idx_api_keys_user_id")
}

model audit_logs {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  entity_type String   @db.VarChar(255)
  entity_id   String   @db.Uuid
  action      String   @db.VarChar(50)
  old_values  Json?
  new_values  Json?
  ip_address  String?  @db.Inet
  user_agent  String?
  created_at  DateTime @default(now()) @db.Timestamp(6)
  users       users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at], map: "idx_audit_logs_created_at")
  @@index([entity_type, entity_id], map: "idx_audit_logs_entity")
  @@index([user_id], map: "idx_audit_logs_user_id")
}

model availability {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  date       DateTime @db.Date
  start_time DateTime @db.Time(6)
  end_time   DateTime @db.Time(6)
  status     String?  @default("Available") @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([date], map: "idx_availability_date")
  @@index([user_id], map: "idx_availability_user_id")
}

model capacity {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String    @db.Uuid
  week_start          DateTime  @db.Date
  allocated_hours     Decimal?  @db.Decimal(8, 2)
  scheduled_hours     Decimal?  @db.Decimal(8, 2)
  utilization_percent Decimal?  @db.Decimal(5, 2)
  calculated_at       DateTime? @default(now()) @db.Timestamp(6)
  users               users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id], map: "idx_capacity_user_id")
  @@index([week_start], map: "idx_capacity_week_start")
}

model channels {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String                  @db.VarChar(255)
  description           String?
  type                  String?                 @default("Public") @db.VarChar(50)
  dm_key                String?                 @unique @db.VarChar(80)
  created_by            String                  @db.Uuid
  members               String[]                @db.Uuid
  created_at            DateTime                @default(now()) @db.Timestamp(6)
  archived_at           DateTime?               @db.Timestamp(6)
  users                 users                   @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  message_notifications message_notifications[]
  messages              messages[]

  @@index([created_by], map: "idx_channels_created_by")
  @@index([type], map: "idx_channels_type")
}

model clients {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                     String    @unique @db.VarChar(255)
  allowed_domains          String[]  @default([])
  primary_contact_name     String?   @db.VarChar(255)
  primary_contact_email    String?   @db.VarChar(255)
  primary_contact_phone    String?   @db.VarChar(50)
  contract_type            String?   @default("retainer") @db.VarChar(50)
  monthly_budget           Decimal?  @db.Decimal(12, 2)
  vat_number               String?   @db.VarChar(100)
  status                   String?   @default("active") @db.VarChar(50)
  brand_assets_url         String?
  client_portal_enabled    Boolean?  @default(true)
  invoice_view_enabled     Boolean?  @default(true)
  content_approval_enabled Boolean?  @default(true)
  created_at               DateTime  @default(now()) @db.Timestamp(6)
  updated_at               DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  deleted_at               DateTime? @db.Timestamp(6)
  invoices                 invoices[]
  quotations               quotations[]
  campaigns                campaigns[]
  proposals                proposals[]
  client_portal_tokens     client_portal_tokens[]
  opus_briefs              opus_briefs[]
  tasks                    tasks[]

  @@index([name], map: "idx_clients_name")
  @@index([status], map: "idx_clients_status")
}

model invoice_items {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_id  String   @db.Uuid
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unit_price  Decimal  @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)
  task_id     String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamp(6)
  invoices    invoices @relation(fields: [invoice_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tasks       tasks?   @relation(fields: [task_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([invoice_id], map: "idx_invoice_items_invoice_id")
}

model invoices {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_number      String          @unique @db.VarChar(100)
  client_id           String          @db.Uuid
  status              String?         @default("Draft") @db.VarChar(50)
  currency            String?         @default("EGP") @db.VarChar(10)
  subtotal            Decimal         @db.Decimal(12, 2)
  discount_percentage Decimal?        @default(0) @db.Decimal(5, 2)
  discount_amount     Decimal?        @default(0) @db.Decimal(12, 2)
  vat_percentage      Decimal?        @default(14.00) @db.Decimal(5, 2)
  vat_amount          Decimal         @db.Decimal(12, 2)
  total               Decimal         @db.Decimal(12, 2)
  due_date            DateTime        @db.Date
  sent_at             DateTime?       @db.Timestamp(6)
  paid_at             DateTime?       @db.Timestamp(6)
  created_by          String          @db.Uuid
  created_at          DateTime        @default(now()) @db.Timestamp(6)
  updated_at          DateTime        @default(now()) @updatedAt @db.Timestamp(6)
  deleted_at          DateTime?       @db.Timestamp(6)
  invoice_items       invoice_items[]
  clients             clients         @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               users           @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  quotations          quotations[]

  @@index([client_id], map: "idx_invoices_client_id")
  @@index([status], map: "idx_invoices_status")
  @@index([due_date], map: "idx_invoices_due_date")
}

model quotation_items {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quotation_id String     @db.Uuid
  description  String
  quantity     Decimal    @default(1) @db.Decimal(10, 2)
  unit_price   Decimal    @db.Decimal(12, 2)
  amount       Decimal    @db.Decimal(12, 2)
  created_at   DateTime   @default(now()) @db.Timestamp(6)
  quotations   quotations @relation(fields: [quotation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([quotation_id], map: "idx_quotation_items_quotation_id")
}

model quotations {
  id                      String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quotation_number        String            @unique @db.VarChar(100)
  client_id               String            @db.Uuid
  status                  String?           @default("Draft") @db.VarChar(50)
  currency                String?           @default("EGP") @db.VarChar(10)
  subtotal                Decimal           @db.Decimal(12, 2)
  total                   Decimal           @db.Decimal(12, 2)
  valid_until             DateTime?         @db.Date
  converted_to_invoice_id String?           @db.Uuid
  created_by              String            @db.Uuid
  created_at              DateTime          @default(now()) @db.Timestamp(6)
  updated_at              DateTime          @default(now()) @updatedAt @db.Timestamp(6)
  quotation_items         quotation_items[]
  clients                 clients           @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                   users             @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  converted_invoice       invoices?         @relation(fields: [converted_to_invoice_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  proposals               proposals?

  @@index([client_id], map: "idx_quotations_client_id")
  @@index([status], map: "idx_quotations_status")
}

model proposals {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  proposal_number  String      @unique @db.VarChar(100)
  client_id        String      @db.Uuid
  title            String      @db.VarChar(255)
  summary          String?
  objectives       Json?
  deliverables     Json?
  timeline_weeks   Int?
  budget_estimate  Decimal?    @db.Decimal(12, 2)
  currency         String?     @default("EGP") @db.VarChar(10)
  status           String?     @default("Draft") @db.VarChar(50)
  quotation_id     String?     @unique @db.Uuid
  created_by       String      @db.Uuid
  created_at       DateTime    @default(now()) @db.Timestamp(6)
  updated_at       DateTime    @default(now()) @updatedAt @db.Timestamp(6)
  campaigns        campaigns?
  clients          clients     @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            users       @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  quotations       quotations? @relation(fields: [quotation_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([client_id], map: "idx_proposals_client_id")
  @@index([status], map: "idx_proposals_status")
}

model campaigns {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id   String     @db.Uuid
  name        String     @db.VarChar(255)
  brief       String?
  market      String?    @default("eg") @db.VarChar(20)
  channels    String[]   @default([])
  budget      Decimal?   @db.Decimal(12, 2)
  currency    String?    @default("EGP") @db.VarChar(10)
  start_date  DateTime?  @db.Date
  end_date    DateTime?  @db.Date
  status      String?    @default("Planning") @db.VarChar(50)
  proposal_id String?    @unique @db.Uuid
  created_by  String     @db.Uuid
  created_at  DateTime   @default(now()) @db.Timestamp(6)
  updated_at  DateTime   @default(now()) @updatedAt @db.Timestamp(6)
  deleted_at  DateTime?  @db.Timestamp(6)
  clients     clients    @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users      @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  proposals   proposals? @relation(fields: [proposal_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  opus_briefs opus_briefs?
  opus_campaign_metrics opus_campaign_metrics[]

  @@index([client_id], map: "idx_campaigns_client_id")
  @@index([status], map: "idx_campaigns_status")
  @@index([proposal_id], map: "idx_campaigns_proposal_id")
}

model collaborations {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_by  String   @db.Uuid
  title       String   @db.VarChar(255)
  description String?
  members     String[] @db.Uuid
  status      String?  @default("Active") @db.VarChar(50)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @default(now()) @db.Timestamp(6)
  users       users    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_by], map: "idx_collaborations_created_by")
}

model departments {
  id                                     String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                   String           @db.VarChar(255)
  description                            String?
  head_id                                String?          @db.Uuid
  budget                                 Decimal?         @db.Decimal(12, 2)
  created_at                             DateTime         @default(now()) @db.Timestamp(6)
  updated_at                             DateTime         @default(now()) @db.Timestamp(6)
  deleted_at                             DateTime?        @db.Timestamp(6)
  users_departments_head_idTousers       users?           @relation("departments_head_idTousers", fields: [head_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  task_templates                         task_templates[]
  tasks                                  tasks[]
  users_users_department_idTodepartments users[]          @relation("users_department_idTodepartments")

  @@index([name], map: "idx_departments_name")
}

model email_verification_tokens {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  token_hash  String    @unique @db.VarChar(255)
  expires_at  DateTime  @db.Timestamp(6)
  consumed_at DateTime? @db.Timestamp(6)
  created_at  DateTime  @default(now()) @db.Timestamp(6)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_email_verification_tokens_expires_at")
  @@index([user_id], map: "idx_email_verification_tokens_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model feedback_360 {
  id                                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_id                           String   @db.Uuid
  reviewer_id                           String   @db.Uuid
  category                              String?  @db.VarChar(100)
  rating                                Int?
  comment                               String?
  anonymous                             Boolean? @default(false)
  created_at                            DateTime @default(now()) @db.Timestamp(6)
  users_feedback_360_employee_idTousers users    @relation("feedback_360_employee_idTousers", fields: [employee_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_feedback_360_reviewer_idTousers users    @relation("feedback_360_reviewer_idTousers", fields: [reviewer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([employee_id], map: "idx_feedback_360_employee_id")
  @@index([reviewer_id], map: "idx_feedback_360_reviewer_id")
}

model holidays {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date           DateTime @db.Date
  name           String   @db.VarChar(255)
  country        String?  @db.VarChar(50)
  is_working_day Boolean? @default(false)
  created_at     DateTime @default(now()) @db.Timestamp(6)

  @@index([country], map: "idx_holidays_country")
  @@index([date], map: "idx_holidays_date")
}

model kpis {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_id String   @db.Uuid
  metric_name String   @db.VarChar(255)
  value       Decimal  @db.Decimal(12, 2)
  target      Decimal? @db.Decimal(12, 2)
  period      String?  @default("Monthly") @db.VarChar(50)
  measured_at DateTime @db.Timestamp(6)
  source      String?  @default("Manual") @db.VarChar(100)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  users       users    @relation(fields: [employee_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([employee_id], map: "idx_kpis_employee_id")
  @@index([measured_at], map: "idx_kpis_measured_at")
  @@index([metric_name], map: "idx_kpis_metric_name")
}

model leave_requests {
  id                                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                                 String   @db.Uuid
  start_date                              DateTime @db.Date
  end_date                                DateTime @db.Date
  type                                    String   @db.VarChar(50)
  reason                                  String?
  approver_id                             String?  @db.Uuid
  status                                  String?  @default("Pending") @db.VarChar(50)
  created_at                              DateTime @default(now()) @db.Timestamp(6)
  updated_at                              DateTime @default(now()) @db.Timestamp(6)
  users_leave_requests_approver_idTousers users?   @relation("leave_requests_approver_idTousers", fields: [approver_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_leave_requests_user_idTousers     users    @relation("leave_requests_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id, start_date, end_date], map: "idx_leave_requests_date_range")
  @@index([status], map: "idx_leave_requests_status")
  @@index([user_id], map: "idx_leave_requests_user_id")
}

model mentions {
  id                                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mentioned_user_id                       String   @db.Uuid
  mentioned_by                            String   @db.Uuid
  entity_type                             String   @db.VarChar(100)
  entity_id                               String   @db.Uuid
  context                                 String?
  read                                    Boolean? @default(false)
  created_at                              DateTime @default(now()) @db.Timestamp(6)
  users_mentions_mentioned_byTousers      users    @relation("mentions_mentioned_byTousers", fields: [mentioned_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_mentions_mentioned_user_idTousers users    @relation("mentions_mentioned_user_idTousers", fields: [mentioned_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([mentioned_user_id], map: "idx_mentions_mentioned_user_id")
  @@index([read], map: "idx_mentions_read")
}

model message_notifications {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  channel_id String    @db.Uuid
  message_id String?   @db.Uuid
  type       String?   @db.VarChar(50)
  read       Boolean?  @default(false)
  created_at DateTime  @default(now()) @db.Timestamp(6)
  channels   channels  @relation(fields: [channel_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages   messages? @relation(fields: [message_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([read], map: "idx_message_notifications_read")
  @@index([user_id], map: "idx_message_notifications_user_id")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model messages {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channel_id            String                  @db.Uuid
  user_id               String                  @db.Uuid
  content               String
  attachments           Json?
  reactions             Json?
  thread_id             String?                 @db.Uuid
  edited_at             DateTime?               @db.Timestamp(6)
  deleted_at            DateTime?               @db.Timestamp(6)
  created_at            DateTime                @default(now()) @db.Timestamp(6)
  message_notifications message_notifications[]
  channels              channels                @relation(fields: [channel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages              messages?               @relation("messagesTomessages", fields: [thread_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_messages        messages[]              @relation("messagesTomessages")
  users                 users                   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([channel_id], map: "idx_messages_channel_id")
  @@index([created_at], map: "idx_messages_created_at")
  @@index([thread_id], map: "idx_messages_thread_id")
  @@index([user_id], map: "idx_messages_user_id")
}

model okrs {
  id                            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_id                   String   @db.Uuid
  objective                     String   @db.VarChar(255)
  key_results                   Json
  quarter                       String   @db.VarChar(10)
  year                          Int
  status                        String?  @default("On Track") @db.VarChar(50)
  owner_id                      String?  @db.Uuid
  created_at                    DateTime @default(now()) @db.Timestamp(6)
  updated_at                    DateTime @default(now()) @db.Timestamp(6)
  users_okrs_employee_idTousers users    @relation("okrs_employee_idTousers", fields: [employee_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_okrs_owner_idTousers    users?   @relation("okrs_owner_idTousers", fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([employee_id], map: "idx_okrs_employee_id")
  @@index([quarter, year], map: "idx_okrs_quarter_year")
}

model password_reset_tokens {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  token_hash   String    @unique @db.VarChar(255)
