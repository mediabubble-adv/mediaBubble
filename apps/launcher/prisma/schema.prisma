model tasks {
  id                             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                          String             @db.VarChar(255)
  description                    String?
  created_by                     String             @db.Uuid
  assigned_to                    String?            @db.Uuid
  department_id                  String?            @db.Uuid
  priority                       String?            @default("Medium") @db.VarChar(50)
  status                         String?            @default("Backlog") @db.VarChar(50)
  due_date                       DateTime?          @db.Date
  completed_at                   DateTime?          @db.Timestamp(6)
  estimated_hours                Decimal?           @db.Decimal(8, 2)
  actual_hours                   Decimal?           @db.Decimal(8, 2)
  tags                           String[]
  parent_task_id                 String?            @db.Uuid
  created_at                     DateTime           @default(now()) @db.Timestamp(6)
  updated_at                     DateTime           @default(now()) @db.Timestamp(6)
  deleted_at                     DateTime?          @db.Timestamp(6)
  task_attachments               task_attachments[]
  task_comments                  task_comments[]
  users_tasks_assigned_toTousers users?             @relation("tasks_assigned_toTousers", fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_tasks_created_byTousers  users              @relation("tasks_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  departments                    departments?       @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tasks                          tasks?             @relation("tasksTotasks", fields: [parent_task_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_tasks                    tasks[]            @relation("tasksTotasks")
  time_entries                   time_entries[]

  @@index([assigned_to], map: "idx_tasks_assigned_to")
  @@index([created_by], map: "idx_tasks_created_by")
  @@index([department_id], map: "idx_tasks_department_id")
  @@index([due_date], map: "idx_tasks_due_date")
  @@index([due_date, status], map: "idx_tasks_due_date_status")
  @@index([status], map: "idx_tasks_status")
  @@index([updated_at], map: "idx_tasks_updated_at")
}

model time_entries {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String   @db.Uuid
  task_id          String?  @db.Uuid
  date             DateTime @db.Date
  start_time       DateTime @db.Timestamp(6)
  end_time         DateTime @db.Timestamp(6)
  duration_minutes Int?
  description      String?
  billable         Boolean? @default(false)
  status           String?  @default("Draft") @db.VarChar(50)
  created_at       DateTime @default(now()) @db.Timestamp(6)
  updated_at       DateTime @default(now()) @db.Timestamp(6)
  tasks            tasks?   @relation(fields: [task_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([date], map: "idx_time_entries_date")
  @@index([user_id, date], map: "idx_time_entries_date_range")
  @@index([task_id], map: "idx_time_entries_task_id")
  @@index([user_id], map: "idx_time_entries_user_id")
}

model user_presence {
  user_id          String    @id @db.Uuid
  status           String?   @default("Offline") @db.VarChar(50)
  last_seen        DateTime? @default(now()) @db.Timestamp(6)
  current_location String?   @db.VarChar(255)
  device           String?   @db.VarChar(100)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)
  users            users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id                                                         String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                                      String                      @unique @db.VarChar(255)
  password_hash                                              String?                     @db.VarChar(255)
  name                                                       String                      @db.VarChar(255)
  avatar_url                                                 String?
  department_id                                              String?                     @db.Uuid
  role                                                       String                      @default("Contributor") @db.VarChar(50)
  status                                                     String?                     @default("active") @db.VarChar(50)
  last_login_at                                              DateTime?                   @db.Timestamp(6)
  created_at                                                 DateTime                    @default(now()) @db.Timestamp(6)
  updated_at                                                 DateTime                    @default(now()) @db.Timestamp(6)
  deleted_at                                                 DateTime?                   @db.Timestamp(6)
  activity_logs                                              activity_logs[]
  ai_configurations                                          ai_configurations[]
  ai_outputs                                                 ai_outputs[]
  ai_requests                                                ai_requests[]
  api_keys                                                   api_keys[]
  audit_logs                                                 audit_logs[]
  availability                                               availability[]
  capacity                                                   capacity[]
  channels                                                   channels[]
  collaborations                                             collaborations[]
  departments_departments_head_idTousers                     departments[]               @relation("departments_head_idTousers")
  email_verification_tokens                                  email_verification_tokens[]
  feedback_360_feedback_360_employee_idTousers               feedback_360[]              @relation("feedback_360_employee_idTousers")
  feedback_360_feedback_360_reviewer_idTousers               feedback_360[]              @relation("feedback_360_reviewer_idTousers")
  kpis                                                       kpis[]
  leave_requests_leave_requests_approver_idTousers           leave_requests[]            @relation("leave_requests_approver_idTousers")
  leave_requests_leave_requests_user_idTousers               leave_requests[]            @relation("leave_requests_user_idTousers")
  mentions_mentions_mentioned_byTousers                      mentions[]                  @relation("mentions_mentioned_byTousers")
  mentions_mentions_mentioned_user_idTousers                 mentions[]                  @relation("mentions_mentioned_user_idTousers")
  message_notifications                                      message_notifications[]
  messages                                                   messages[]
  okrs_okrs_employee_idTousers                               okrs[]                      @relation("okrs_employee_idTousers")
  okrs_okrs_owner_idTousers                                  okrs[]                      @relation("okrs_owner_idTousers")
  password_reset_tokens                                      password_reset_tokens[]
  performance_reviews_performance_reviews_employee_idTousers performance_reviews[]       @relation("performance_reviews_employee_idTousers")
  performance_reviews_performance_reviews_reviewer_idTousers performance_reviews[]       @relation("performance_reviews_reviewer_idTousers")
  prompt_executions                                          prompt_executions[]
  prompt_libraries                                           prompt_libraries[]
  prompt_versions                                            prompt_versions[]
  prompts                                                    prompts[]
  settings                                                   settings[]
  task_attachments                                           task_attachments[]
  task_comments                                              task_comments[]
  task_templates                                             task_templates[]
  tasks_tasks_assigned_toTousers                             tasks[]                     @relation("tasks_assigned_toTousers")
  tasks_tasks_created_byTousers                              tasks[]                     @relation("tasks_created_byTousers")
  time_entries                                               time_entries[]
  user_presence                                              user_presence?
  departments_users_department_idTodepartments               departments?                @relation("users_department_idTodepartments", fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_users_department")
  workflow_executions                                        workflow_executions[]
  workflow_templates                                         workflow_templates[]
  workflows                                                  workflows[]

  @@index([department_id], map: "idx_users_department_id")
  @@index([email], map: "idx_users_email")
  @@index([role], map: "idx_users_role")
}

model workflow_executions {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflow_id       String    @db.Uuid
  triggered_by      String?   @db.Uuid
  trigger_data      Json?
  status            String?   @default("Running") @db.VarChar(50)
  steps_executed    Int?
  error_message     String?
  execution_time_ms Int?
  created_at        DateTime  @default(now()) @db.Timestamp(6)
  users             users?    @relation(fields: [triggered_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  workflows         workflows @relation(fields: [workflow_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status], map: "idx_workflow_executions_status")
  @@index([workflow_id], map: "idx_workflow_executions_workflow_id")
}

model workflow_templates {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @db.VarChar(255)
  category        String?  @db.VarChar(100)
  description     String?
  workflow_config Json?
  created_by      String   @db.Uuid
  usage_count     Int?     @default(0)
  created_at      DateTime @default(now()) @db.Timestamp(6)
  users           users    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([category], map: "idx_workflow_templates_category")
}

model workflows {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String                @db.VarChar(255)
  description         String?
  trigger             Json
  steps               Json
  enabled             Boolean?              @default(true)
  created_by          String                @db.Uuid
  last_executed_at    DateTime?             @db.Timestamp(6)
  execution_count     Int?                  @default(0)
  success_count       Int?                  @default(0)
  created_at          DateTime              @default(now()) @db.Timestamp(6)
  updated_at          DateTime              @default(now()) @db.Timestamp(6)
  workflow_executions workflow_executions[]
  users               users                 @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_by], map: "idx_workflows_created_by")
  @@index([enabled], map: "idx_workflows_enabled")
}
