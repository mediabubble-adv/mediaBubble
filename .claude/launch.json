{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Next.js Production Preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview"],
      "port": 3000
    },
    {
      "name": "Brand Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:brand"],
      "port": 3002,
      "autoPort": false
    },
    {
      "name": "Launcher Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:launcher"],
      "port": 3003,
      "autoPort": false
    }
  ]
}
