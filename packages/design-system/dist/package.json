      "types": "./dist/tailwind-preset.d.ts"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.3.0",
    "lucide-react": "^0.294.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}