{
  "name": "@mediabubble/design-system",
  "version": "1.0.0",
  "main": "./index.cjs.js",
  "module": "./index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
