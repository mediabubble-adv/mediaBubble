# Copy this file to .env.local and fill in the values.

# ─── Impeccable (design agent context) ───────────────────────────────────────
# Points PRODUCT.md / DESIGN.md loaders at docs/planning (not repo root).
IMPECCABLE_CONTEXT_DIR=docs/planning
# Never commit .env.local — it is gitignored by Next.js.
# After filling in values on Vercel dashboard, run:
#   vercel env pull .env.local --yes

# ─── Site ─────────────────────────────────────────────────────────────────────
# Egypt marketing (web-eg). Use http://localhost:3001 for web-ae, :3002 for brand.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public business phone for JSON-LD and contact surfaces (E.164 format).
NEXT_PUBLIC_BUSINESS_PHONE=+201234567890

# ─── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# Prefixed NEXT_PUBLIC_ because gtag runs in the browser.
NEXT_PUBLIC_GA4_ID=

# ─── Contact form — email delivery (Resend) ───────────────────────────────────
# Create a free API key at https://resend.com
# Your sending domain must be verified in the Resend dashboard first.
RESEND_API_KEY=

# Inbox that receives contact form submissions.
# Defaults to hello@mediabubble.com when not set.
CONTACT_EMAIL=hello@mediabubble.com

# ─── CRM — HubSpot ────────────────────────────────────────────────────────────
# Private app access token: HubSpot > Settings > Integrations > Private Apps
# Required scopes: crm.objects.contacts.write, crm.objects.contacts.read
# Used by /api/contact (lead upsert) and /api/hubspot (newsletter signups).
HUBSPOT_API_KEY=

# ─── Content pipeline — UAE localization (optional) ───────────────────────────
# Used only by packages/content-pipeline to localize web-eg copy for web-ae.
# When unset, the pipeline passes content through unchanged (no build impact).
OPENAI_API_KEY=
